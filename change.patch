diff --git a/app/tests/configure_hq.Tests.ps1 b/app/tests/configure_hq.Tests.ps1
index 1111111..2222222 100644
--- a/app/tests/configure_hq.Tests.ps1
+++ b/app/tests/configure_hq.Tests.ps1
@@ -81,3 +81,47 @@ Describe "configure_hq" {
         Assert-MockCalled Bring-HqDisksOnline -Times 1 -Exactly
     }
 }
+
+Context "Get-HqLabChildVhdDiscovery" {
+    It "returns the writable Lab child VHDX candidate and rejects the parent path" {
+        # Section: keep the first iSCSI slice at discovery by proving we pick the Lab child disk,
+        # not the immutable parent image, before any target provisioning work begins.
+        $roleDefinitions = @(
+            [pscustomobject]@{
+                RoleName = 'Repository'
+                SourceVhd = 'M:\repository1.vhdx'
+                VhdName = 'repository1.vhdx'
+                ExpectedDriveLetter = 'R'
+            }
+            [pscustomobject]@{
+                RoleName = 'Lab'
+                SourceVhd = 'V:\VHDs\Lab\lab-child.vhdx'
+                VhdName = 'lab-child.vhdx'
+                ExpectedDriveLetter = 'W'
+            }
+            [pscustomobject]@{
+                RoleName = 'Backups'
+                SourceVhd = 'X:\backup1.vhdx'
+                VhdName = 'backup1.vhdx'
+                ExpectedDriveLetter = 'B'
+            }
+        )
+
+        $vhdInfo = [pscustomobject]@{
+            VhdType = 'Differencing'
+            Path = 'V:\VHDs\Lab\lab-child.vhdx'
+            ParentPath = 'V:\VHDs\Lab\lab-parent.vhdx'
+        }
+
+        Mock Get-HqDiskRoleDefinitions { $roleDefinitions }
+        Mock Get-VHD { $vhdInfo }
+
+        $result = Get-HqLabChildVhdDiscovery
+
+        $result.RoleName | Should Be 'Lab'
+        $result.ChildPath | Should Be 'V:\VHDs\Lab\lab-child.vhdx'
+        $result.ParentPath | Should Be 'V:\VHDs\Lab\lab-parent.vhdx'
+        $result.VhdType | Should Be 'Differencing'
+
+        Assert-MockCalled Get-HqDiskRoleDefinitions -Times 1 -Exactly
+        Assert-MockCalled Get-VHD -Times 1 -Exactly -ParameterFilter { $Path -eq 'V:\VHDs\Lab\lab-child.vhdx' }
+    }
+}
