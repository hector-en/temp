$script:HqDiskMetadataConfig = [pscustomobject]@{
    AvailableVmNames = @(
        'HQ-DC01'
    )
    SelectedVmName = 'HQ-DC01'

    RoleDefinitions = @(
        [pscustomobject]@{
            VmName = 'HQ-DC01'
            SourceVhd = 'M:\repository1.vhdx'
            VhdName = 'repository1.vhdx'
            RoleName = 'Repository'
            ExpectedDriveLetter = 'R'
