            Principal = 'HQ\Repo_R'
            AccessLevel = 'ReadAndExecute'
            ServiceAccount = 'HQ\svc_repo'
            ServiceAccessLevel = 'FullControl'
        }
    )

    SecurityPrincipalDefinitions = @(
        [pscustomobject]@{
            Principal = 'HQ\Repo_R'
            Type = 'Group'
